# ============================================================
# AegisTwin Environment Configuration
# Copy this file to .env and fill in real values
# ============================================================

# ----- Application -----
APP_NAME=AegisTwin
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ----- PostgreSQL -----
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=aegistwin
POSTGRES_USER=aegistwin
POSTGRES_PASSWORD=aegistwin_dev_password
DATABASE_URL=postgresql+asyncpg://aegistwin:aegistwin_dev_password@db:5432/aegistwin

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ----- Celery -----
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----- JWT Auth -----
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- LLM Integration (optional -- mock used if not set) -----
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# LLM_PROVIDER=openai
LLM_PROVIDER=mock

# ----- Tool Broker -----
TOOL_MODE=mock
# Set to "real" to use actual tool integrations when adapters are built

# ----- Deception (optional) -----
# Leave blank or remove this line if not using webhook alerts
DECEPTION_ALERT_WEBHOOK=

# ----- Frontend -----
VITE_API_BASE_URL=http://localhost:8000/api/v1
